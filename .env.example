# ============================================================
# SOMA · Environment Variables
# Copy this file to ".env.local" and fill in your real values.
# NEVER commit .env.local. It is gitignored.
# ============================================================

# --- Firebase (from Firebase Console > Project Settings) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# --- AI Provider ---
# We use Groq (free, no card). Get a key at https://console.groq.com/keys
# The code is pluggable: to switch to a paid provider later, you only change this var + one config file.
GROQ_API_KEY=your_groq_api_key_here

# --- Email (Resend, free tier 100/day) ---
# Get a key at https://resend.com (can be deferred; weekly reports will show a "coming soon" toast without it)
RESEND_API_KEY=your_resend_api_key_here

# --- Internal security ---
# Choose any secure random strings for these
ADMIN_SECRET=choose_a_secure_string_here
CRON_SECRET=choose_a_secure_string_here
